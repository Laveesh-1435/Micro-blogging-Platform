<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Flitter - Bookmarks</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="style2.css">
    <style>
        .container {
            display: flex;
            max-width: 1200px;
            margin: 0 auto;
            background-color: white;
        }

        /* Sidebar Styles */
        .sidebar {
            width: 250px;
            padding: 20px;
            border-right: 1px solid #eee;
        }

        .nav-item {
            display: flex;
            align-items: center;
            padding: 10px 0;
            cursor: pointer;
        }

        .nav-item i {
            margin-right: 10px;
            font-size: 1.2em;
        }

        .nav-item.active {
            color: #1da1f2;
            font-weight: bold;
        }

        .flitter-btn {
            width: 100%;
            padding: 10px;
            background-color: #1da1f2;
            color: white;
            border: none;
            border-radius: 20px;
            font-weight: bold;
            margin-top: 15px;
        }

        /* Main Content Styles */
        .main-content {
            flex-grow: 1;
            border-right: 1px solid #eee;
        }

        .bookmarks-header {
            display: flex;
            align-items: center;
            padding: 15px;
            border-bottom: 1px solid #eee;
        }

        .bookmarks-title {
            font-size: 1.3em;
            font-weight: bold;
            margin-left: 10px;
        }

        /* Bookmarks List Styles */
        .bookmarks-container {
            padding: 10px;
        }

        .bookmark-item {
            display: flex;
            padding: 15px 10px;
            border-bottom: 1px solid #eee;
        }

        .bookmark-avatar {
            margin-right: 10px;
        }

        .bookmark-avatar img {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            object-fit: cover;
            background-color: #f0f0f0;
        }

        .bookmark-content {
            flex-grow: 1;
        }

        .bookmark-header {
            display: flex;
            align-items: center;
            margin-bottom: 5px;
        }

        .bookmark-author {
            font-weight: bold;
            margin-right: 5px;
        }

        .bookmark-handle {
            color: #657786;
            margin-right: 5px;
        }

        .bookmark-timestamp {
            color: #657786;
            font-size: 0.9em;
        }

        .bookmark-text {
            margin-bottom: 10px;
        }

        .bookmark-actions {
            display: flex;
            justify-content: space-between;
            color: #657786;
        }

        .bookmark-action-icon {
            margin-right: 15px;
            cursor: pointer;
        }

        .no-bookmarks {
            text-align: center;
            color: #657786;
            padding: 20px;
            background-color: #f9f9f9;
            border-radius: 10px;
        }

        /* Right Sidebar Styles */
        .right-sidebar {
            width: 350px;
            padding: 20px;
        }

        .search-container {
            position: relative;
            margin-bottom: 20px;
        }

        .search-input {
            width: 100%;
            padding: 10px 40px;
            border: 1px solid #eee;
            border-radius: 20px;
        }

        .search-icon {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #657786;
        }

        /* Responsive Design */
        @media (max-width: 768px) {
            .container {
                flex-direction: column;
            }

            .sidebar, .main-content, .right-sidebar {
                width: 100%;
            }
        }
        .suggestion-pic {
    width: 40px; /* Set the width */
    height: 40px; /* Set the height */
    border-radius: 50%; /* Make it round */
    object-fit: cover; /* Ensure the image covers the area without distortion */
    margin-right: 10px; /* Optional, to add space between the image and the text */
}

    </style>
</head>
<body>
    <div class="container">
        <!-- Left Sidebar -->
        <div class="sidebar">
            <div class="logo">
                <i class="fab fa-twitter animate-pulse"></i>
                <span>Flitter</span>
            </div>
            
            <div class="nav-item active">
                <i class="fas fa-home"></i>
                <a href="/dashboard">
                <span>Home</span>
                </a>
            </div>    
            <div class="nav-item">
                <i class="far fa-bookmark"></i>
                <a href="/bookmarks">
                <span>Bookmark</span>
                </a>
            </div>
            <div class="nav-item">
                <i class="far fa-user"></i>
                <a href="/profile">
                <span>Profile</span>
                </a>
            </div>
            
            <button class="flitter-btn">Flitt</button>
            
            <div class="profile-preview">
                <img src="profile.jpg" alt="Profile Picture" class="profile-pic">
                <div class="profile-info">
                    <div class="profile-name">Mohit Aggarwal</div>
                    <div class="profile-handle">MohitA1122</div>
                </div>
            </div>
        </div>
        
        <!-- Main Content -->
        <div class="main-content">
            <div class="bookmarks-header">
                <i class="far fa-bookmark"></i>
                <div class="bookmarks-title">Bookmarks</div>
            </div>
            
            <div class="bookmarks-container">
                <% if (bookmarks.length > 0) { %>
                    <% bookmarks.forEach(function(bookmark) { %>
                        <div class="bookmark-item">
                            <div class="bookmark-avatar">
                                <img src="<%= bookmark.authorPic %>" alt="User Avatar">
                            </div>
                            <div class="bookmark-content">
                                <div class="bookmark-header">
                                    <span class="bookmark-author"><%= bookmark.author %></span>
                                    <span class="bookmark-handle">@<%= bookmark.handle %></span>
                                    <span class="bookmark-timestamp"><%= bookmark.timestamp %></span>
                                </div>
                                <p class="bookmark-text"><%= bookmark.content %></p>
                                <div class="bookmark-actions">
                                    <div>
                                        <i class="far fa-comment bookmark-action-icon"></i>
                                        <i class="far fa-heart bookmark-action-icon"></i>
                                        <i class="far fa-share-square bookmark-action-icon"></i>
                                    </div>
                                    <i class="fas fa-bookmark"></i>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="no-bookmarks">
                        You have no bookmarks yet.
                    </div>
                <% } %>
            </div>
        </div>
        
        <!-- Right Sidebar -->
        <div class="right-sidebar">
            <div class="search-container">
                <input type="text" class="search-input" placeholder="Search">
                <i class="fas fa-search search-icon"></i>
            </div>

            <h3>Trending</h3>
            <% trends.forEach(function(trend) { %>
                <div class="trend">
                    <span><%= trend.category %></span>
                    <div><%= trend.name %></div>
                    <small><%= trend.count %></small>
                </div>
            <% }); %>

            <h3>Suggestions</h3>
            <% suggestions.forEach(function(suggestion) { %>
                <div class="suggestion">
                    <img src="<%= suggestion.profilePic %>" alt="Profile Picture" class="suggestion-pic">
                    <div>
                        <strong><%= suggestion.name %></strong>
                        <span>@<%= suggestion.handle %></span>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>
</body>
</html>
