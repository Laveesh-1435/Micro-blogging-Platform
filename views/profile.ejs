<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Flitter - <%= user.name %>'s Profile</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="style2.css">
</head>
<body>
    <div id="toast" class="toast">
        <i class="fas fa-check-circle"></i>
        <span id="toast-message">Your flitt was posted!</span>
    </div>
    
    <div class="container">
        <div class="left-sidebar sidebar">
            <div class="logo">
                <i class="fab fa-twitter animate-pulse"></i>
                <span>Flitter</span>
            </div>
            
            <div class="nav-item active">
                <i class="fas fa-home"></i>
                <a href="/dashboard">
                <span>Home</span>
                </a>
            </div>    
            <div class="nav-item">
                <i class="far fa-bookmark"></i>
                <a href="/bookmarks">
                <span>Bookmark</span>
                </a>
            </div>
            <div class="nav-item">
                <i class="far fa-user"></i>
                <a href="/profile">
                <span>Profile</span>
                </a>
            </div>
            
            <button class="flitter-btn">Flitt</button>
            
            <div class="profile-preview">
                <div class="profile-details">
                    <img src="<%= user.profilePic %>" alt="Profile Picture" class="profile-pic">
                    <div class="profile-info">
                        <div class="profile-name"><%= user.name %></div>
                        <div class="profile-handle">@<%= user.username %></div>
                    </div>
                </div>
                <div class="profile-more">
                    <i class="fas fa-ellipsis-h"></i>
                </div>
            
                <div class="logout-menu">
                    <button class="logout-button">
                        <i class="fas fa-sign-out-alt"></i>
                        <a href="/logout">Logout</a>
                    </button>
                </div>
            </div>
            
            <div class="logout-menu">
                <div class="logout-menu-item">Add an existing account</div>
                <div class="logout-menu-item logout">Log out @<%= user.username %></div>
            </div>
        </div>
        
        <div class="main-content">
            <div class="profile-header">
                <div class="back-arrow">
                    <i class="fas fa-arrow-left"></i>
                </div>
                <div>
                    <div class="profile-title"><%= (user.name && user.name !== 'New User') ? user.name : user.username %></div>
                    <div class="profile-subtitle"><%= user.flitts ? user.flitts.length : 0 %> Flitts</div>
                </div>
            </div>
            
            <div class="profile-banner" style="background-image: url('<%= user.bannerImage %>');"></div>
            
            <div class="profile-avatar">
                <img src="<%= user.profilePic %>" alt="<%= user.name %>'s profile picture" class="avatar-img profile-avatar-img">
            </div>
            
            <button class="edit-profile-btn">Edit profile</button>
            
            <button class="verify-btn">
                <i class="fas fa-check-circle"></i>
                Get verified
            </button>
            
            <div class="profile-info">
                <div class="profile-display-name">
                    <%= user.name %>
                    <span class="verified-badge">
                        <i class="fas fa-check-circle"></i>
                    </span>
                </div>

                <div class="profile-display-name">
                    <%= (user.name && user.name !== 'New User') ? user.name : user.username %>
                    <span class="verified-badge">
                        <i class="fas fa-check-circle"></i>
                    </span>
                </div>
                <!-- <div class="profile-username">@<%= user.username %></div> -->
                
                <% if (user.website) { %>
                    <div class="profile-bio">
                        <%= user.bio %>
                    </div>
                <% } %>
                
                <div class="profile-metadata">
                    <% if (user.website) { %>
                        <div class="profile-location">
                            <i class="fas fa-map-marker-alt"></i>
                            <%= user.location %>
                        </div>
                    <% } %>
                    
                    <% if (user.website) { %>
                        <div class="profile-website">
                            <i class="fas fa-link"></i>
                            <a href="<%= user.website %>"><%= user.website.replace('https://', '') %></a>
                        </div>
                    <% } %>
                    
                    <div class="profile-join-date">
                        <i class="far fa-calendar"></i>
                        Joined <%= user.joinDate %>
                    </div>
                </div>
                
                <div class="profile-stats">
                    <div class="stat">
                        <span class="stat-value"><%= user.following %></span>
                        <span class="stat-label">Following</span>
                    </div>
                    <div class="stat">
                        <span class="stat-value"><%= user.followers %></span>
                        <span class="stat-label">Followers</span>
                    </div>
                </div>
            </div>
            
            <div class="tabs">
                <div class="tab active" data-tab="flitts">Flitts</div>
                <div class="tab" data-tab="replies">Replies</div>
                <div class="tab" data-tab="media">Media</div>
                <div class="tab" data-tab="likes">Likes</div>
            </div>
            
            <div id="flitts-content" class="tab-content active">
                <div class="flitts-container">
                    <% if (flitts && flitts.length > 0) { %>
                        <% flitts.forEach(function(flitt) { %>
                        <div class="flitt-item">
                            <div class="flitt-avatar">
                                <img src="<%= user.profilePic || '/profile.jpg' %>" alt="Profile picture">
                            </div>
                            <div class="flitt-content">
                                <p><%= flitt.content %></p>
                                <div class="flitt-timestamp"><%= flitt.createdAt ? new Date(flitt.createdAt).toLocaleString() : 'Just now' %></div>
                            </div>
                        </div>
                        <% }); %>
                    <% } else { %>
                        <div class="no-content">
                            <p>No Flitts posted yet.</p>
                        </div>
                    <% } %>
                </div>
            </div>
            
            <div id="replies-content" class="tab-content">
                <div class="replies-container">
                    <% if (user.replies && user.replies.length > 0) { %>
                        <% user.replies.forEach(function(reply) { %>
                        <div class="reply-item">
                            <div class="reply-avatar">
                                <img src="<%= user.profilePic %>" alt="<%= user.name %>'s profile picture">
                            </div>
                            <div class="reply-content">
                                <div class="reply-header">
                                    <span class="reply-author"><%= user.name %></span>
                                    <span class="reply-handle">@<%= user.username %></span>
                                    <span class="reply-timestamp"><%= reply.timestamp %></span>
                                </div>
                                <p class="reply-text"><%= reply.content %></p>
                                <div class="original-flitt-content">
                                    <div class="original-flitt-avatar">
                                        <img src="<%= reply.originalFlitt.authorPic %>" alt="<%= reply.originalFlitt.author %>'s profile picture">
                                    </div>
                                    <span class="original-flitt-author"><%= reply.originalFlitt.author %></span>
                                    <p><%= reply.originalFlitt.content %></p>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                    <% } else { %>
                        <div class="no-content">
                            <p>No replies yet</p>
                        </div>
                    <% } %>
                </div>
            </div>
            
            <div id="media-content" class="tab-content">
                <div class="media-container">
                    <% if (user.media && user.media.length > 0) { %>
                        <div class="media-grid">
                            <% user.media.forEach(function(mediaItem) { %>
                            <div class="media-item">
                                <img src="<%= mediaItem.url %>" alt="<%= mediaItem.description %>">
                                <div class="media-overlay">
                                    <span class="media-timestamp"><%= mediaItem.timestamp %></span>
                                </div>
                            </div>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <div class="no-content">
                            <p>No media posted</p>
                        </div>
                    <% } %>
                </div>
            </div>
            
            <div id="likes-content" class="tab-content">
                <div class="likes-container">
                    <% if (user.likes && user.likes.length > 0) { %>
                        <% user.likes.forEach(function(likedFlitt) { %>
                        <div class="liked-flitt-item">
                            <div class="liked-flitt-avatar">
                                <img src="<%= likedFlitt.authorPic %>" alt="<%= likedFlitt.author %>'s profile picture">
                            </div>
                            <div class="liked-flitt-content">
                                <div class="liked-flitt-header">
                                    <span class="liked-flitt-author"><%= likedFlitt.author %></span>
                                    <span class="liked-flitt-handle">@<%= likedFlitt.username %></span>
                                    <span class="liked-flitt-timestamp"><%= likedFlitt.timestamp %></span>
                                </div>
                                <p class="liked-flitt-text"><%= likedFlitt.content %></p>
                            </div>
                            <div class="liked-flitt-actions">
                                <i class="fas fa-heart liked-icon"></i>
                            </div>
                        </div>
                        <% }); %>
                    <% } else { %>
                        <div class="no-content">
                            <p>No liked Flitts</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
        
        <div class="right-sidebar sidebar">
            <div class="search-container">
                <i class="fas fa-search search-icon"></i>
                <input type="text" class="search-input" placeholder="Search Flitter">
            </div>
            
            <div class="trends">
                <div class="section-header">
                    Trends for you
                    <i class="fas fa-cog trend-settings"></i>
                </div>
                
                <% trends.forEach(function(trend) { %>
                <div class="trend-item">
                    <div class="trend-category"><%= trend.category %></div>
                    <div class="trend-name"><%= trend.name %></div>
                    <div class="trend-count"><%= trend.count %></div>
                </div>
                <% }); %>
                
                <div class="show-more">
                    Show more
                </div>
            </div>
            
            <div class="follow-suggestions">
                <div class="section-header">
                    Who to follow
                </div>
                
                <% suggestions.forEach(function(suggestion) { %>
                <div class="follow-item">
                    <img src="<%= suggestion.profilePic %>" alt="<%= suggestion.name %>" class="follow-profile-pic">
                    <div class="follow-info">
                        <div class="follow-name"><%= suggestion.name || suggestion.username %></div>
                        <div class="follow-name"><%= (suggestion.name && suggestion.name !== 'New User') ? suggestion.name : suggestion.username %></div>
                        <div class="follow-handle">@<%= suggestion.username %></div>
                    </div>
                    <button class="follow-btn">Follow</button>
                </div>
                <% }); %>
                
                <div class="show-more">
                    Show more
                </div>
            </div>
            
            <div class="footer">
                <a href="#">Terms of Service</a>
                <a href="#">Privacy Policy</a>
                <a href="#">Cookie Policy</a>
                <a href="#">Accessibility</a>
                <a href="#">Ads info</a>
                <a href="#">More...</a>
                <span>© <%= new Date().getFullYear() %> Flitter, Inc.</span>
            </div>
        </div>
    </div>
    
    <div id="flitt-modal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <span class="close-modal">&times;</span>
                <h2>Compose new Flitt</h2>
            </div>
            <div class="modal-body">
                <div class="modal-compose">
                    <img src="<%= user.profilePic %>" alt="Profile Picture" class="modal-profile-pic">
                    <textarea class="modal-input" placeholder="What's happening?"></textarea>
                </div>
                <div class="modal-tools">
                    <div class="compose-tools">
                        <div class="compose-tool">
                            <i class="far fa-image"></i>
                        </div>
                        <div class="compose-tool">
                            <i class="fas fa-poll-h"></i>
                        </div>
                        <div class="compose-tool">
                            <i class="far fa-smile"></i>
                        </div>
                        <div class="compose-tool">
                            <i class="far fa-calendar"></i>
                        </div>
                    </div>
                    <button class="compose-button modal-post-btn" disabled>Flitt</button>
                </div>
            </div>
        </div>
    </div>

    <div class="mobile-nav">
        <div class="mobile-nav-item active">
            <i class="fas fa-home"></i>
        </div>
        <div class="mobile-nav-item">
            <i class="fas fa-search"></i>
        </div>
        <div class="mobile-nav-item">
            <i class="far fa-bell"></i>
        </div>
        <div class="mobile-nav-item">
            <i class="far fa-envelope"></i>
        </div>
    </div>

    <script>
        // Tab Switching
        document.querySelectorAll('.tab').forEach(tab => {
            tab.addEventListener('click', () => {
                document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
                document.querySelectorAll('.tab-content').forEach(tc => tc.classList.remove('active'));
                
                tab.classList.add('active');
                document.getElementById(`${tab.dataset.tab}-content`).classList.add('active');
            });
        });

        // Flitt Modal Functionality
        const flitterBtn = document.querySelector('.flitter-btn');
        const flittModal = document.getElementById('flitt-modal');
        const closeModal = document.querySelector('.close-modal');
        const modalInput = document.querySelector('.modal-input');
        const modalPostBtn = document.querySelector('.modal-post-btn');

        flitterBtn.addEventListener('click', () => {
            flittModal.style.display = 'block';
        });

        closeModal.addEventListener('click', () => {
            flittModal.style.display = 'none';
        });

        window.addEventListener('click', (event) => {
            if (event.target === flittModal) {
                flittModal.style.display = 'none';
            }
        });

        modalInput.addEventListener('input', () => {
            modalPostBtn.disabled = modalInput.value.trim() === '';
        });

        modalPostBtn.addEventListener('click', () => {
            const flittContent = modalInput.value.trim();
            if (flittContent) {
                const toast = document.getElementById('toast');
                const toastMessage = document.getElementById('toast-message');
                
                toastMessage.textContent = 'Your flitt was posted!';
                toast.classList.add('show');
                
                flittModal.style.display = 'none';
                modalInput.value = '';
                
                setTimeout(() => {
                    toast.classList.remove('show');
                }, 3000);
            }
        });

        // Dropdown and More Options
        const profileMore = document.querySelector('.profile-more');
        const logoutMenu = document.querySelector('.profile-preview .logout-menu');

        profileMore.addEventListener('click', () => {
            logoutMenu.classList.toggle('show');
        });

        document.addEventListener('click', (event) => {
            if (!profileMore.contains(event.target) && !logoutMenu.contains(event.target)) {
                logoutMenu.classList.remove('show');
            }
        });
    </script>
</body>
</html>