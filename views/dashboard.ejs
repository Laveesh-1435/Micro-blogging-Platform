<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Flitter - Share your thoughts</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="style.css">
  
</head>
<body>
    <div id="toast" class="toast">
        <i class="fas fa-check-circle"></i>
        <span id="toast-message">Your flitt was posted!</span>
    </div>
    
    <div class="container">
        <!-- Left Sidebar -->
        <div class="left-sidebar sidebar">
            <div class="logo">
                <i class="fab fa-twitter animate-pulse"></i>
                <span>Flitter</span>
            </div>
            
           <div class="nav-item active">
                <i class="fas fa-home"></i>
                <a href="/dashboard">
                <span>Home</span>
                </a>
            </div>    
            <div class="nav-item">
                <i class="far fa-bookmark"></i>
                <a href="/bookmarks">
                <span>Bookmark</span>
                </a>
            </div>
            <div class="nav-item">
                <i class="far fa-user"></i>
                <a href="/profile">
                <span>Profile</span>
                </a>
            </div>
            <button class="flitter-btn">Flitt</button>
            
            <div class="profile-preview">
                <div class="profile-details">
                    <img src="/profile.jpg"alt="Profile Picture" class="profile-pic">
                    <div class="profile-info">
                        <div class="profile-name"><%= user.name %></div>
                        <div class="profile-handle">@<%= user.handle %></div>
                    </div>
                </div>
                <div class="profile-more">
                    <i class="fas fa-ellipsis-h"></i>
                </div>
            
                <!-- Logout Dropdown Menu -->
                <div class="logout-menu">
                    <button class="logout-button">
                        <i class="fas fa-sign-out-alt"></i>
                        <a href="api/logout">Logout</a>
                    </button>
                </div>
            
            </div>
            
            <!-- Logout Dropdown Menu -->
            <div class="logout-menu">
                <div class="logout-menu-item">Add an existing account</div>
                <div class="logout-menu-item logout">Log out @<%= user.handle %></div>
            </div>
        </div>
        
        <!-- Main Content -->
        <div class="main-content">
            <div class="home-header">
                <div class="home-title">Home</div>
                <div class="tabs">
                    <div class="tab active">For you</div>
                    <div class="tab">Following</div>
                </div>
                <button id="mode-toggle" class="mode-toggle" aria-label="Toggle dark mode">
                    <i class="fas fa-moon"></i>
                </button>
            </div>
            
            <div class="compose-area">
                <form action="/api/posts" method="POST">
                    <div class="compose-input-container">
                        <img src="<%= user.profilePic %>" alt="Profile" class="compose-profile-pic">
                        <textarea name="content" class="compose-input" placeholder="What's happening?" required></textarea>
                    </div>
                    
                    <div class="compose-actions">
                        <div class="compose-tools">
                            <div class="compose-tool" title="Media">
                                <i class="far fa-image"></i>
                            </div>
                            <div class="compose-tool" title="GIF">
                                <i class="far fa-file-image"></i>
                            </div>
                            <div class="compose-tool" title="Poll">
                                <i class="fas fa-poll-h"></i>
                            </div>
                            <div class="compose-tool" title="Emoji">
                                <i class="far fa-smile"></i>
                            </div>
                            <div class="compose-tool" title="Schedule">
                                <i class="far fa-calendar"></i>
                            </div>
                            <div class="compose-tool" title="Location">
                                <i class="fas fa-map-marker-alt"></i>
                            </div>
                        </div>
                        
                        <button type="submit" class="compose-button">Flitt</button>
                    </div>
                </form>
            </div>
            
            <div class="feed">
                <% flitts.forEach(function(flitt) { %>
                <!-- Post -->
                <div class="flitt">
                    <img src="<%= flitt.author.profilePic %>" alt="<%= flitt.author.name %> Profile" class="flitt-profile-pic">
                    <div class="flitt-content">
                        <div class="flitt-header">
                            <span class="flitt-name"><%= flitt.author.name %></span>
                            <span class="flitt-handle">@<%= flitt.author.handle %></span>
                            <span class="flitt-time">· <%= flitt.timePosted %></span>
                            <div class="flitt-more">
                                <i class="fas fa-ellipsis-h"></i>
                            </div>
                        </div>
                        <div class="flitt-text">
                            <%= flitt.text %>
                            <% if (flitt.hashtags && flitt.hashtags.length > 0) { %>
                                <% flitt.hashtags.forEach(function(hashtag) { %>
                                    <a href="#" class="flitt-link">#<%= hashtag %></a>
                                <% }); %>
                            <% } %>
                        </div>
                        <% if (flitt.image) { %>
                            <img src="<%= flitt.image %>" alt="<%= flitt.imageAlt || 'Flitt Image' %>" class="flitt-img">
                        <% } %>
                        <div class="flitt-actions">
                            <div class="flitt-action reply" data-count="<%= flitt.replies.length %>">
                                <i class="far fa-comment"></i>
                                <span><%= flitt.replies.length %></span>
                            </div>
                            <div class="flitt-action reflitt" data-count="<%= flitt.reflitts %>">
                                <i class="fas fa-retweet"></i>
                                <span><%= flitt.reflitts %></span>
                            </div>
                            <div class="flitt-action like" data-count="<%= flitt.likes %>">
                                <i class="far fa-heart"></i>
                                <span><%= flitt.likes %></span>
                            </div>
                            <div class="flitt-action share">
                                <i class="far fa-share-square"></i>
                            </div>
                        </div>

                        <!-- Comments Section (initially hidden) -->
                        <div class="comments-section">
                            <div class="comment-input-container">
                                <img src="<%= user.profilePic %>" alt="Your Profile" class="comment-profile-pic">
                                <textarea class="comment-input" placeholder="Post your reply"></textarea>
                                <button class="comment-button" disabled>Reply</button>
                            </div>
                            <% flitt.replies.forEach(function(reply) { %>
                            <div class="comment">
                                <img src="<%= reply.author.profilePic %>" alt="<%= reply.author.name %> Profile" class="comment-profile-pic">
                                <div class="comment-content">
                                    <div class="comment-header">
                                        <span class="comment-name"><%= reply.author.name %></span>
                                        <span class="comment-handle">@<%= reply.author.handle %></span>
                                        <span class="comment-time">· <%= reply.timePosted %></span>
                                    </div>
                                    <div class="comment-text">
                                        <%= reply.text %>
                                    </div>
                                    <div class="comment-actions">
                                        <div class="comment-action reply">
                                            <i class="far fa-comment"></i>
                                        </div>
                                        <div class="comment-action like" data-count="<%= reply.likes %>">
                                            <i class="far fa-heart"></i>
                                            <span><%= reply.likes %></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% }); %>
                        </div>
                    </div>
                </div>
                <% }); %>

                <div class="loading-dots">
                    <div class="dot"></div>
                    <div class="dot"></div>
                    <div class="dot"></div>
                </div>
            </div>
        </div>
        
        <!-- Right Sidebar -->
        <div class="right-sidebar sidebar">
            <div class="search-container">
                <i class="fas fa-search search-icon"></i>
                <input type="text" class="search-input" placeholder="Search Flitter">
            </div>
            
            <div class="trends">
                <div class="section-header">
                    Trends for you
                    <i class="fas fa-cog trend-settings"></i>
                </div>
                
                <% trends.forEach(function(trend) { %>
                <div class="trend-item">
                    <div class="trend-category"><%= trend.category %></div>
                    <div class="trend-name"><%= trend.name %></div>
                    <div class="trend-count"><%= trend.count %></div>
                </div>
                <% }); %>
                
                <div class="show-more">
                    Show more
                </div>
            </div>
            
            <div class="follow-suggestions">
                <div class="section-header">
                    Who to follow
                </div>
                
                <% suggestions.forEach(function(suggestion) { %>
                <div class="follow-item">
                    <img src="<%= suggestion.profilePic %>" alt="<%= suggestion.name %>" class="follow-profile-pic">
                    <div class="follow-info">
                        <div class="follow-name"><%= suggestion.name %></div>
                        <div class="follow-handle">@<%= suggestion.handle %></div>
                    </div>
                    <button class="follow-btn">Follow</button>
                </div>
                <% }); %>
                
                <div class="show-more">
                    Show more
                </div>
            </div>
            
            <div class="footer">
                <a href="#">Terms of Service</a>
                <a href="#">Privacy Policy</a>
                <a href="#">Cookie Policy</a>
                <a href="#">Accessibility</a>
                <a href="#">Ads info</a>
                <a href="#">More...</a>
                <span>© <%= new Date().getFullYear() %> Flitter, Inc.</span>
            </div>
        </div>
    </div>
    
    <!-- Mobile Navigation -->
    <div class="mobile-nav">
        <div class="mobile-nav-item active">
            <i class="fas fa-home"></i>
        </div>
        <div class="mobile-nav-item">
            <i class="fas fa-search"></i>
        </div>
        <div class="mobile-nav-item">
            <i class="far fa-bell"></i>
        </div>
        <div class="mobile-nav-item">
            <i class="far fa-envelope"></i>
        </div>
    </div>

    <!-- Flitt Modal -->
    <div id="flitt-modal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <span class="close-modal">&times;</span>
                <h2>Compose new Flitt</h2>
            </div>
            <div class="modal-body">
                <form action="/api/posts" method="POST">
                    <div class="modal-compose">
                        <img src="<%= user.profilePic %>" alt="Profile Picture" class="modal-profile-pic">
                        <textarea name="content" class="modal-input" placeholder="What's happening?" required></textarea>
                    </div>
                    <div class="modal-tools">
                        <div class="compose-tools">
                            <div class="compose-tool">
                                <i class="far fa-image"></i>
                            </div>
                            <div class="compose-tool">
                                <i class="fas fa-poll-h"></i>
                            </div>
                            <div class="compose-tool">
                                <i class="far fa-smile"></i>
                            </div>
                            <div class="compose-tool">
                                <i class="far fa-calendar"></i>
                            </div>
                        </div>
                        <button type="submit" class="compose-button modal-post-btn">Flitt</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <script src="script.js"></script>
</body>
</html>